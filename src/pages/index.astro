import Hero from "../components/Hero.astro";
import Expertise from "../components/Expertise.astro";
import Solutions from "../components/Solutions.astro";
import FinalCTA from "../components/FinalCTA.astro";
---

<Layout
	title="RAIL — Ingeniería de software a medida"
	description="Consultora de ingeniería de software que construye sistemas que escalan: ERP, CRM, automatización, IA y datos, e infraestructura cloud a medida para tu negocio."
>
	<Header />
	<main id="contenido">
		<Hero />
		<Expertise />
		<Solutions />
		<FinalCTA />
