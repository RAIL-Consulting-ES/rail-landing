---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
---

<Layout title="RAIL — Engineering the Future">
	<Header />
	<Hero />
	<section id="expertise" class="next-placeholder">
		<div class="next-placeholder__inner">
			<p class="label-caps">Next Section</p>
		</div>
	</section>
</Layout>

<style>
	.next-placeholder {
		position: relative;
		z-index: 2;
		min-height: 100vh;
		background: var(--surface-container-low);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.next-placeholder__inner {
		color: var(--on-surface-variant);
	}
</style>

<script>
	import "../scripts/hero.ts";
</script>
