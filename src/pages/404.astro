---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
---

<Layout
	title="Página no encontrada (404) — RAIL"
	description="La página que buscas no existe o se ha movido. Vuelve al inicio o explora las soluciones de ingeniería de software de RAIL."
	noindex={true}
>
	<Header />

	<main id="contenido" class="notfound">
		<p class="notfound__code" aria-hidden="true">404</p>
		<h1 class="notfound__title">Esta página se ha perdido.</h1>
		<p class="notfound__lead">
			El enlace que has seguido no existe o la página se ha movido. No te
			preocupes: desde aquí puedes volver al camino principal.
		</p>

		<div class="notfound__actions">
			<a href="/" class="cta label-caps notfound__cta">Volver al inicio</a>
			<a href="/solutions/" class="notfound__link">Ver soluciones</a>
			<a href="/contact/" class="notfound__link">Contacto</a>
		</div>
	</main>
</Layout>

<style>
	.notfound {
		max-width: 760px;
		margin: 0 auto;
		padding: 24vh var(--margin-edge) var(--stack-lg);
		text-align: center;
	}

	.notfound__code {
		margin: 0;
		font-family: "Space Grotesk", "Inter", sans-serif;
		font-size: clamp(96px, 20vw, 200px);
		font-weight: 700;
		line-height: 0.9;
		letter-spacing: -0.05em;
		color: transparent;
		background: linear-gradient(
			180deg,
			var(--on-surface) 0%,
			var(--tertiary) 160%
		);
		-webkit-background-clip: text;
		background-clip: text;
	}

	.notfound__title {
		margin: var(--stack-sm) 0 var(--stack-md);
		font-size: clamp(32px, 5vw, 56px);
		font-weight: 800;
		letter-spacing: -0.04em;
		line-height: 1.05;
	}

	.notfound__lead {
		margin: 0 auto var(--stack-lg);
		max-width: 52ch;
		font-size: clamp(16px, 2vw, 19px);
		line-height: 1.6;
		color: var(--on-surface-variant);
	}

	.notfound__actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: var(--stack-md);
	}

	.notfound__cta {
		background: var(--tertiary);
		color: var(--on-tertiary);
		padding: 14px 26px;
		border-radius: var(--r);
		transition:
			transform 200ms ease,
			filter 200ms ease;
	}

	.notfound__cta:hover {
		transform: scale(1.02);
		filter: brightness(0.97);
	}

	.notfound__link {
		font-weight: 600;
		font-size: 15px;
		color: var(--on-surface-variant);
		transition: color 200ms ease;
	}

	.notfound__link:hover {
		color: var(--on-surface);
	}

	@media (max-width: 768px) {
		.notfound {
			padding: 20vh var(--stack-md) var(--stack-lg);
		}
	}
</style>
