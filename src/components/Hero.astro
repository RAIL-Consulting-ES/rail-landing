---
---

<section class="hero" id="hero">
	<div class="hero__inner">
		<div class="hero__glow" aria-hidden="true"></div>
		<h1 class="hero__title" aria-label="RAIL">
			<span class="letter letter--r">R</span><span class="letter letter--a"
				>A</span
			><span class="letter letter--i">I</span><span class="letter letter--l"
				>L</span
			>
		</h1>
		<div class="hero__subtitle">
			<span class="sub sub--1">Ingeniería del futuro</span>
			<span class="sub sub--2">Integrando Inteligencia Artificial</span>
		</div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		height: 300vh;
		background: var(--surface);
	}

	.hero__inner {
		position: sticky;
		top: 0;
		height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		overflow: hidden;
	}

	.hero__glow {
		position: absolute;
		inset: 0;
		pointer-events: none;
		background:
			radial-gradient(
				ellipse 60% 50% at 50% 50%,
				rgba(255, 255, 255, 1) 0%,
				rgba(255, 255, 255, 0.6) 25%,
				rgba(147, 197, 114, 0.06) 55%,
				transparent 75%
			),
			radial-gradient(
				ellipse 80% 60% at 50% 60%,
				rgba(226, 226, 226, 0.5) 0%,
				transparent 70%
			);
		filter: blur(20px);
		z-index: 0;
	}

	.hero__title {
		position: relative;
		z-index: 1;
		margin: 0;
		display: flex;
		font-family: "Inter", sans-serif;
		font-weight: 800;
		font-size: clamp(96px, 18vw, 260px);
		line-height: 1;
		letter-spacing: -0.04em;
		user-select: none;
	}

	.letter {
		display: inline-block;
		will-change: transform, opacity;
		background: linear-gradient(
			180deg,
			#0a0a0a 0%,
			#1b1b1b 55%,
			#5d5f5f 100%
		);
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
		color: transparent;
	}

	.hero__subtitle {
		position: relative;
		z-index: 1;
		margin-top: var(--stack-md);
		height: 1.4em;
		width: min(90vw, 720px);
		text-align: center;
	}

	.sub {
		position: absolute;
		left: 0;
		right: 0;
		top: 0;
		font-family: "Inter", sans-serif;
		font-size: clamp(20px, 2.4vw, 32px);
		font-weight: 600;
		line-height: 1.3;
		letter-spacing: -0.01em;
		color: var(--on-surface-variant);
		will-change: opacity, transform;
	}

	.sub--2 {
		opacity: 0;
	}
</style>
