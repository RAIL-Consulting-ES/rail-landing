---

<section class="sol" id="solutions" aria-label="Solutions">
	<div class="sol__track">
		<div class="sol__stage">
			<div class="bulb" aria-hidden="true">
				<span class="bulb__cord"></span>
				<span class="bulb__sway">
					<span class="bulb__halo"></span>
					<span class="bulb__glass">
						<img class="bulb__img bulb__img--off" src="/bombilla_off.svg" alt="" />
						<img class="bulb__img bulb__img--on" src="/bombilla_on.svg" alt="" />
					</span>
				</span>
			</div>

			<h2 class="sol__title">Solutions</h2>

			<div class="sol__deck">
				<div class="sol__cards">
					{
						solutions.map((s, i) => (
							<article
								class={`card card--${s.theme}`}
								data-card={i}
								style={`--cw:${s.w}px;--ch:${s.h}px;`}
							>
								<svg
									class="card__icon"
									viewBox="0 0 80 60"
									role="img"
									aria-label={s.title}
									set:html={s.icon}
								/>
								<h3 class="card__title">{s.title}</h3>
								<p class="card__copy">{s.copy}</p>
							</article>
						))
					}
				</div>

				<div class="sol__scratch" aria-hidden="true">
					<svg
						class="sol__scratch-svg"
						width="100%"
						height="100%"
						preserveAspectRatio="none"
					>
						<defs>
							<filter id="solNoise">
								<feTurbulence
									type="fractalNoise"
									baseFrequency="0.85"
									numOctaves="2"
									stitchTiles="stitch"
								></feTurbulence>
								<feColorMatrix
									type="matrix"
									values="0 0 0 0 0.7
													0 0 0 0 0.7
													0 0 0 0 0.7
													0 0 0 1 0"
								></feColorMatrix>
							</filter>
						</defs>
						<rect width="100%" height="100%" fill="#1f1f1f"></rect>
						<rect
							width="100%"
							height="100%"
							filter="url(#solNoise)"
							opacity="0.65"
						></rect>
					</svg>
					<span class="sol__scratch-tag label-caps">Spoiler · Encender luz</span>
				</div>
			</div>

			<a href="/solutions" class="cta-primary">Ver todas las soluciones</a>
		</div>
	</div>
</section>

<style>
	.sol {
		position: relative;
		z-index: 3;
		margin-top: -100vh;
	}

	.sol__track {
		height: 700vh;
	}

	.sol__stage {
		position: sticky;
		top: 0;
		height: 100vh;
		overflow: hidden;
		background-color: #000;
		color: #ffffff;
	}

	/* Bulb pinned to top of viewport (dropping from header) */
	.bulb {
		position: absolute;
		left: 50%;
		top: 0;
		transform: translateX(-50%);
		display: flex;
		flex-direction: column;
		align-items: center;
		pointer-events: none;
		z-index: 5;
	}

	.bulb__cord {
		display: block;
		width: 2px;
		height: 8vh;
		background: linear-gradient(180deg, #303030 0%, #1b1b1b 100%);
		transform-origin: top center;
		transform: scaleY(0);
	}

	.bulb__sway {
		display: block;
		position: relative;
		transform-origin: top center;
	}

	.bulb__halo {
		position: absolute;
		left: 50%;
		top: 80%;
		width: 160vmin;
		height: 160vmin;
		transform: translate(-50%, -50%) scale(0.4);
		background: radial-gradient(
			circle,
			rgba(189, 241, 153, 0.55) 0%,
			rgba(147, 197, 114, 0.32) 14%,
			rgba(147, 197, 114, 0.12) 32%,
			rgba(0, 0, 0, 0) 60%
		);
		opacity: 0;
		pointer-events: none;
		filter: blur(10px);
	}

	.bulb__glass {
		position: relative;
		display: block;
		width: 70px;
		height: 124px;
	}

	.bulb__img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: contain;
		pointer-events: none;
		transform: rotate(180deg);
	}

	.bulb__img--on {
		opacity: 0;
	}

	/* Title — same size as Expertise panels */
	.sol__title {
		position: absolute;
		left: 50%;
		top: 25%;
		transform: translate(-50%, -50%);
		margin: 0;
		font-family: "Inter", sans-serif;
		font-size: clamp(56px, 9vw, 120px);
		font-weight: 800;
		letter-spacing: -0.04em;
		line-height: 1;
		text-align: center;
		color: #ffffff;
		clip-path: circle(0% at 50% -10%);
		opacity: 0;
		pointer-events: none;
		z-index: 3;
	}

	/* Cards deck */
	.sol__deck {
		position: absolute;
		left: 50%;
		top: 62%;
		transform: translate(-50%, -50%);
		width: 92vw;
		height: 280px;
		pointer-events: none;
		z-index: 2;
	}

	.sol__cards {
		position: relative;
		width: 100%;
		height: 100%;
	}

	.card {
		position: absolute;
		left: 50%;
		top: 50%;
		width: var(--cw);
		height: var(--ch);
		border-radius: var(--r-xl);
		padding: 16px;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		gap: 8px;
		box-shadow: 0 28px 70px -34px rgba(0, 0, 0, 0.45);
		opacity: 0;
		will-change: transform, opacity;
	}

	.card--light {
		background: var(--surface-container-lowest);
		color: var(--on-surface);
		border: 1px solid var(--outline-variant);
	}
	.card--soft {
		background: var(--surface-container-high);
		color: var(--on-surface);
	}
	.card--dark {
		background: #1b1b1b;
		color: #f1f1f1;
	}
	.card--tinted {
		background: #093b00;
		color: #bdf199;
	}

	.card__icon {
		width: 44px;
		height: 33px;
		color: currentColor;
	}

	.card__title {
		margin: 0;
		font-size: 17px;
		font-weight: 700;
		letter-spacing: -0.01em;
	}

	.card__copy {
		margin: 0;
		font-size: 11px;
		line-height: 1.45;
		opacity: 0.85;
	}

	/* Scratch overlay — sits on top of the cards deck like a spoiler tag */
	.sol__scratch {
		position: absolute;
		inset: 0;
		border-radius: var(--r-lg);
		overflow: hidden;
		pointer-events: none;
		z-index: 20;
		box-shadow:
			0 0 0 1px rgba(255, 255, 255, 0.06),
			0 30px 60px -30px rgba(0, 0, 0, 0.6);
	}

	.sol__scratch-svg {
		position: absolute;
		inset: 0;
		display: block;
	}

	.sol__scratch-tag {
		position: absolute;
		left: 50%;
		top: 50%;
		transform: translate(-50%, -50%);
		color: #c6c6c6;
		letter-spacing: 0.3em;
		font-size: 14px;
		text-shadow: 0 1px 2px rgba(0, 0, 0, 0.6);
	}

	/* CTA */
	.cta-primary {
		position: absolute;
		left: 50%;
		bottom: 6vh;
		transform: translate(-50%, 20px);
		background: var(--tertiary);
		color: var(--on-tertiary);
		padding: 14px 28px;
		border-radius: var(--r);
		font-weight: 600;
		font-size: 14px;
		letter-spacing: 0.02em;
		opacity: 0;
		z-index: 6;
		transition: transform 220ms ease, box-shadow 220ms ease;
	}

	.cta-primary:hover {
		transform: translate(-50%, 18px) scale(1.02);
		box-shadow: 0 14px 32px -14px rgba(147, 197, 114, 0.6);
	}

	@media (prefers-reduced-motion: reduce) {
		.sol__track {
			height: auto;
		}
		.sol__stage {
			position: static;
			height: auto;
			background: var(--surface);
			color: var(--on-surface);
			padding: var(--stack-lg) 0;
		}
		.bulb {
			position: relative;
			top: auto;
			margin-bottom: var(--stack-md);
		}
		.bulb__cord {
			height: 60px;
			transform: scaleY(1);
		}
		.bulb__halo {
			display: none;
		}
		.sol__title {
			position: relative;
			top: auto;
			left: auto;
			transform: none;
			clip-path: none;
			opacity: 1;
			color: var(--on-surface);
			margin: var(--stack-md) 0;
		}
		.sol__deck {
			position: relative;
			top: auto;
			transform: none;
			pointer-events: auto;
			overflow-x: auto;
		}
		.sol__cards {
			justify-content: flex-start;
		}
		.card {
			opacity: 1;
		}
		.sol__scratch {
			display: none;
		}
		.cta-primary {
			position: relative;
			left: auto;
			bottom: auto;
			transform: none;
			margin: var(--stack-lg) auto 0;
			display: inline-block;
			opacity: 1;
		}
	}
</style>
