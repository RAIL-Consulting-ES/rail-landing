---
const panels = [
	{
		id: "strategy",
		title: "Strategy",
		copy: "High-end technological roadmap designed aligned with ultimate business objectives. Precision planning for scalable futures.",
	},
	{
		id: "architecture",
		title: "Architecture",
		copy: "Building robust, fault-tolerant system frameworks. Structural integrity meets uncompromising performance.",
	},
	{
		id: "execution",
		title: "Execution",
		copy: "Flawless deployment and operational excellence. Turning complex blueprints into living digital ecosystems.",
	},
];
---

<section class="exp" id="expertise" aria-label="Expertise">
	<div class="exp__track">
		<div class="exp__stage">
			<article class="panel" data-panel="strategy" aria-hidden="true">
				<p class="label-caps panel__tag">01 — Strategy</p>
				<h2 class="panel__title">Strategy</h2>
				<p class="panel__copy">{panels[0].copy}</p>
				<svg
					class="panel__gfx panel__gfx--strategy"
					viewBox="0 0 800 220"
					role="img"
					aria-label="Train moving along rails"
				>
					<g class="rails">
						<line
							class="rail-line rail-line--top"
							x1="0"
							y1="130"
							x2="800"
							y2="130"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
						></line>
						<line
							class="rail-line rail-line--bot"
							x1="0"
							y1="150"
							x2="800"
							y2="150"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
						></line>
						{
							Array.from({ length: 16 }).map((_, i) => (
								<line
									class="tie"
									x1={20 + i * 50}
									y1="124"
									x2={20 + i * 50}
									y2="156"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
								/>
							))
						}
					</g>
					<g class="train" transform="translate(820 110)">
						<rect
							x="-70"
							y="-26"
							width="70"
							height="32"
							rx="4"
							fill="var(--tertiary)"
						></rect>
						<rect
							x="-130"
							y="-22"
							width="56"
							height="28"
							rx="3"
							fill="#1b1b1b"
						></rect>
						<rect
							x="-190"
							y="-22"
							width="56"
							height="28"
							rx="3"
							fill="#4c4546"
						></rect>
						<circle cx="-14" cy="14" r="6" fill="#1b1b1b"></circle>
						<circle cx="-46" cy="14" r="6" fill="#1b1b1b"></circle>
						<circle cx="-94" cy="14" r="6" fill="#1b1b1b"></circle>
						<circle cx="-118" cy="14" r="6" fill="#1b1b1b"></circle>
						<circle cx="-156" cy="14" r="6" fill="#1b1b1b"></circle>
						<circle cx="-178" cy="14" r="6" fill="#1b1b1b"></circle>
					</g>
				</svg>
			</article>

			<article class="panel" data-panel="architecture" aria-hidden="true">
				<p class="label-caps panel__tag">02 — Architecture</p>
				<h2 class="panel__title">Architecture</h2>
				<p class="panel__copy">{panels[1].copy}</p>
				<svg
					class="panel__gfx panel__gfx--architecture"
					viewBox="0 0 960 360"
					role="img"
					aria-label="Block diagram of connected services"
				>
					<defs>
						<filter id="archShadow" x="-20%" y="-20%" width="140%" height="140%">
							<feDropShadow
								dx="0"
								dy="2"
								stdDeviation="3"
								flood-color="#000"
								flood-opacity="0.08"
							></feDropShadow>
						</filter>
					</defs>

					<g class="links" fill="none" stroke="#1b1b1b" stroke-width="1.5" stroke-linecap="round">
						<path data-link="0" d="M 180 90 C 250 90, 270 180, 340 180"></path>
						<path data-link="1" d="M 180 270 C 250 270, 270 180, 340 180"></path>
						<path data-link="2" d="M 500 180 C 570 180, 590 90, 660 90"></path>
						<path data-link="3" d="M 500 180 C 570 180, 590 180, 660 180"></path>
						<path data-link="4" d="M 500 180 C 570 180, 590 270, 660 270"></path>
					</g>

					<g class="blocks">
						<g class="block" data-block="0" transform="translate(60 50)">
							<rect width="120" height="80" rx="10" fill="#ffffff" stroke="#1b1b1b" stroke-width="1.5" filter="url(#archShadow)"></rect>
							<circle cx="20" cy="40" r="10" fill="#93c572"></circle>
							<rect x="40" y="28" width="64" height="8" rx="2" fill="#1b1b1b"></rect>
							<rect x="40" y="44" width="44" height="6" rx="2" fill="#cfc4c5"></rect>
							<circle cx="120" cy="40" r="4" fill="#1b1b1b"></circle>
						</g>
						<g class="block" data-block="1" transform="translate(60 230)">
							<rect width="120" height="80" rx="10" fill="#ffffff" stroke="#1b1b1b" stroke-width="1.5" filter="url(#archShadow)"></rect>
							<rect x="14" y="30" width="20" height="20" rx="3" fill="#1b1b1b"></rect>
							<rect x="40" y="28" width="64" height="8" rx="2" fill="#1b1b1b"></rect>
							<rect x="40" y="44" width="50" height="6" rx="2" fill="#cfc4c5"></rect>
							<circle cx="120" cy="40" r="4" fill="#1b1b1b"></circle>
						</g>
						<g class="block" data-block="2" transform="translate(340 140)">
							<rect width="160" height="80" rx="10" fill="#1b1b1b" stroke="#1b1b1b" stroke-width="1.5" filter="url(#archShadow)"></rect>
							<circle cx="20" cy="40" r="10" fill="#93c572"></circle>
							<rect x="40" y="28" width="100" height="8" rx="2" fill="#ffffff"></rect>
							<rect x="40" y="44" width="70" height="6" rx="2" fill="#7e7576"></rect>
							<circle cx="0" cy="40" r="4" fill="#1b1b1b"></circle>
							<circle cx="160" cy="40" r="4" fill="#1b1b1b"></circle>
						</g>
						<g class="block" data-block="3" transform="translate(660 50)">
							<rect width="120" height="80" rx="10" fill="#ffffff" stroke="#1b1b1b" stroke-width="1.5" filter="url(#archShadow)"></rect>
							<path d="M 14 38 l 8 -8 l 8 8 l -8 8 z" fill="#93c572" stroke="#1b1b1b" stroke-width="1"></path>
							<rect x="40" y="28" width="64" height="8" rx="2" fill="#1b1b1b"></rect>
							<rect x="40" y="44" width="40" height="6" rx="2" fill="#cfc4c5"></rect>
							<circle cx="0" cy="40" r="4" fill="#1b1b1b"></circle>
						</g>
						<g class="block" data-block="4" transform="translate(660 140)">
							<rect width="120" height="80" rx="10" fill="#ffffff" stroke="#1b1b1b" stroke-width="1.5" filter="url(#archShadow)"></rect>
							<rect x="14" y="30" width="20" height="20" rx="10" fill="#93c572"></rect>
							<rect x="40" y="28" width="64" height="8" rx="2" fill="#1b1b1b"></rect>
							<rect x="40" y="44" width="56" height="6" rx="2" fill="#cfc4c5"></rect>
							<circle cx="0" cy="40" r="4" fill="#1b1b1b"></circle>
						</g>
						<g class="block" data-block="5" transform="translate(660 230)">
							<rect width="120" height="80" rx="10" fill="#ffffff" stroke="#1b1b1b" stroke-width="1.5" filter="url(#archShadow)"></rect>
							<rect x="14" y="32" width="20" height="16" rx="2" fill="#1b1b1b"></rect>
							<rect x="40" y="28" width="64" height="8" rx="2" fill="#1b1b1b"></rect>
							<rect x="40" y="44" width="48" height="6" rx="2" fill="#cfc4c5"></rect>
							<circle cx="0" cy="40" r="4" fill="#1b1b1b"></circle>
						</g>
					</g>

					<g class="pulses">
						<circle class="pulse" data-pulse="0" r="5" cx="180" cy="90" fill="#93c572"></circle>
						<circle class="pulse" data-pulse="1" r="5" cx="180" cy="270" fill="#93c572"></circle>
						<circle class="pulse" data-pulse="2" r="5" cx="500" cy="180" fill="#93c572"></circle>
						<circle class="pulse" data-pulse="3" r="5" cx="500" cy="180" fill="#93c572"></circle>
						<circle class="pulse" data-pulse="4" r="5" cx="500" cy="180" fill="#93c572"></circle>
					</g>
				</svg>
			</article>

			<article class="panel" data-panel="execution" aria-hidden="true">
				<p class="label-caps panel__tag">03 — Execution</p>
				<h2 class="panel__title">Execution</h2>
				<p class="panel__copy">{panels[2].copy}</p>
				<div class="exec-stack">
					<svg
						class="exec exec--blueprint"
						viewBox="0 0 600 360"
						role="img"
						aria-label="Architectural blueprint"
					>
						<defs>
							<pattern
								id="grid"
								width="30"
								height="30"
								patternUnits="userSpaceOnUse"
							>
								<path
									d="M 30 0 L 0 0 0 30"
									fill="none"
									stroke="currentColor"
									stroke-width="0.6"
									opacity="0.45"
								></path>
							</pattern>
						</defs>
						<rect width="600" height="360" fill="url(#grid)"></rect>
						<rect
							x="60"
							y="60"
							width="220"
							height="160"
							fill="none"
							stroke="currentColor"
							stroke-width="1.4"
						></rect>
						<rect
							x="320"
							y="60"
							width="220"
							height="100"
							fill="none"
							stroke="currentColor"
							stroke-width="1.4"
						></rect>
						<rect
							x="320"
							y="180"
							width="220"
							height="120"
							fill="none"
							stroke="currentColor"
							stroke-width="1.4"
						></rect>
						<line
							x1="60"
							y1="260"
							x2="280"
							y2="260"
							stroke="currentColor"
							stroke-width="1.4"
						></line>
						<line
							x1="60"
							y1="280"
							x2="280"
							y2="280"
							stroke="currentColor"
							stroke-width="1.4"
						></line>
					</svg>

					<svg
						class="exec exec--mockup"
						viewBox="0 0 600 360"
						role="img"
						aria-label="Automation UI mockup"
					>
						<rect
							x="20"
							y="20"
							width="560"
							height="320"
							rx="10"
							fill="#ffffff"
							stroke="currentColor"
							stroke-width="1.2"
						></rect>
						<rect
							x="20"
							y="20"
							width="560"
							height="40"
							rx="10"
							fill="#f3f3f3"
						></rect>
						<circle cx="44" cy="40" r="5" fill="#cfc4c5"></circle>
						<circle cx="62" cy="40" r="5" fill="#cfc4c5"></circle>
						<circle cx="80" cy="40" r="5" fill="#cfc4c5"></circle>
						<rect
							x="40"
							y="80"
							width="140"
							height="240"
							rx="6"
							fill="#f9f9f9"
							stroke="currentColor"
							stroke-width="1"
						></rect>
						<rect
							x="56"
							y="100"
							width="108"
							height="12"
							rx="2"
							fill="#1b1b1b"
						></rect>
						<rect
							x="56"
							y="124"
							width="80"
							height="8"
							rx="2"
							fill="#cfc4c5"
						></rect>
						<rect
							x="56"
							y="146"
							width="92"
							height="8"
							rx="2"
							fill="#cfc4c5"
						></rect>
						<rect
							x="56"
							y="168"
							width="70"
							height="8"
							rx="2"
							fill="#cfc4c5"
						></rect>
						<rect
							x="200"
							y="80"
							width="360"
							height="100"
							rx="6"
							fill="#f9f9f9"
							stroke="currentColor"
							stroke-width="1"
						></rect>
						<rect
							x="220"
							y="100"
							width="120"
							height="14"
							rx="2"
							fill="#1b1b1b"
						></rect>
						<rect
							x="220"
							y="126"
							width="240"
							height="8"
							rx="2"
							fill="#cfc4c5"
						></rect>
						<rect
							x="220"
							y="142"
							width="200"
							height="8"
							rx="2"
							fill="#cfc4c5"
						></rect>
						<rect
							x="200"
							y="200"
							width="170"
							height="120"
							rx="6"
							fill="#93c572"
							opacity="0.18"
						></rect>
						<rect
							x="390"
							y="200"
							width="170"
							height="120"
							rx="6"
							fill="#f9f9f9"
							stroke="currentColor"
							stroke-width="1"
						></rect>
						<polyline
							points="220,290 260,260 290,275 320,240 360,255"
							fill="none"
							stroke="#1b1b1b"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
						></polyline>
					</svg>

					<svg
						class="exec exec--rocket"
						viewBox="0 0 220 320"
						role="img"
						aria-label="Rocket launching"
					>
						<defs>
							<linearGradient id="rocketBody" x1="0" y1="0" x2="1" y2="0">
								<stop offset="0%" stop-color="#ffffff"></stop>
								<stop offset="50%" stop-color="#f3f3f3"></stop>
								<stop offset="100%" stop-color="#c6c6c6"></stop>
							</linearGradient>
							<linearGradient id="rocketNose" x1="0" y1="0" x2="1" y2="0">
								<stop offset="0%" stop-color="#1b1b1b"></stop>
								<stop offset="100%" stop-color="#4c4546"></stop>
							</linearGradient>
							<linearGradient id="rocketFin" x1="0" y1="0" x2="0" y2="1">
								<stop offset="0%" stop-color="#1b1b1b"></stop>
								<stop offset="100%" stop-color="#303030"></stop>
							</linearGradient>
							<radialGradient id="rocketWindow" cx="0.4" cy="0.35" r="0.7">
								<stop offset="0%" stop-color="#bdf199"></stop>
								<stop offset="60%" stop-color="#93c572"></stop>
								<stop offset="100%" stop-color="#26500a"></stop>
							</radialGradient>
							<linearGradient id="rocketFlame" x1="0" y1="0" x2="0" y2="1">
								<stop offset="0%" stop-color="#ffffff"></stop>
								<stop offset="35%" stop-color="#bdf199"></stop>
								<stop offset="100%" stop-color="#93c572" stop-opacity="0"></stop>
							</linearGradient>
						</defs>

						<g class="flame-group">
							<path
								class="flame flame--outer"
								d="M86 220 Q110 320 134 220 Q110 248 86 220 Z"
								fill="url(#rocketFlame)"
								opacity="0.7"
							></path>
							<path
								class="flame flame--inner"
								d="M96 220 Q110 290 124 220 Q110 240 96 220 Z"
								fill="#ffffff"
								opacity="0.9"
							></path>
						</g>

						<path
							d="M70 220 L50 250 Q48 256 54 256 L86 244 Z"
							fill="url(#rocketFin)"
						></path>
						<path
							d="M150 220 L170 250 Q172 256 166 256 L134 244 Z"
							fill="url(#rocketFin)"
						></path>

						<path
							d="M86 220
								 L86 110
								 Q86 70 110 30
								 Q134 70 134 110
								 L134 220 Z"
							fill="url(#rocketBody)"
							stroke="#1b1b1b"
							stroke-width="1.5"
						></path>

						<path
							d="M86 110 Q86 70 110 30 Q134 70 134 110 Z"
							fill="url(#rocketNose)"
						></path>

						<circle
							cx="110"
							cy="118"
							r="14"
							fill="url(#rocketWindow)"
							stroke="#1b1b1b"
							stroke-width="1.5"
						></circle>
						<circle cx="105" cy="113" r="4" fill="#ffffff" opacity="0.7"></circle>

						<rect x="86" y="170" width="48" height="2" fill="#1b1b1b" opacity="0.4"></rect>
						<rect x="86" y="192" width="48" height="2" fill="#1b1b1b" opacity="0.4"></rect>

						<path d="M86 220 L134 220" stroke="#1b1b1b" stroke-width="1.5"></path>
					</svg>
				</div>
			</article>

			<div class="exp__blackout" aria-hidden="true"></div>
		</div>
	</div>
</section>

<style>
	.exp {
		position: relative;
		z-index: 4;
		margin-top: -150vh;
	}

	.exp__track {
		height: 650vh;
	}

	.exp__stage {
		position: sticky;
		top: 0;
		height: 100vh;
		overflow: hidden;
	}

	.panel {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		padding: 0 var(--margin-edge);
		opacity: 0;
		transform: scale(0.05);
		transform-origin: 50% 50%;
		will-change: transform, opacity;
		color: var(--on-surface);
	}

	.panel__tag {
		color: var(--on-surface-variant);
		margin-bottom: var(--stack-sm);
	}

	.panel__title {
		margin: 0;
		font-family: "Inter", sans-serif;
		font-size: clamp(56px, 9vw, 120px);
		font-weight: 800;
		letter-spacing: -0.04em;
		line-height: 1;
		background: linear-gradient(180deg, #0a0a0a 0%, #1b1b1b 60%, #5d5f5f 100%);
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
		color: transparent;
	}

	.panel__copy {
		max-width: 640px;
		margin: var(--stack-md) auto 0;
		font-size: clamp(16px, 1.5vw, 20px);
		line-height: 1.6;
		color: var(--on-surface-variant);
	}

	.panel__gfx {
		display: block;
		width: min(80vw, 800px);
		margin-top: var(--stack-lg);
		color: var(--on-surface);
	}

	/* Strategy */
	.panel__gfx--strategy .rail-line {
		stroke-dasharray: 1000;
		stroke-dashoffset: 1000;
	}

	/* Architecture */
	.panel__gfx--architecture .block {
		opacity: 0;
	}
	.panel__gfx--architecture .links path {
		stroke-dasharray: 400;
		stroke-dashoffset: 400;
	}
	.panel__gfx--architecture .pulse {
		opacity: 0;
	}

	/* Execution */
	.exec-stack {
		position: relative;
		width: min(70vw, 600px);
		height: clamp(220px, 36vh, 360px);
		margin-top: var(--stack-md);
	}
	.exec {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		color: var(--on-surface);
	}
	.exec--blueprint {
		opacity: 0;
		color: var(--tertiary);
	}
	.exec--mockup {
		opacity: 0;
	}
	.exec--rocket {
		width: 28%;
		height: auto;
		left: 50%;
		top: 60%;
		transform: translate(-50%, 0) scale(0.6);
		opacity: 0;
	}

	.exp__blackout {
		position: absolute;
		inset: 0;
		background: #000;
		opacity: 0;
		pointer-events: none;
	}

	@media (prefers-reduced-motion: reduce) {
		.exp__track {
			height: auto;
		}
		.exp__stage {
			position: static;
			height: auto;
			display: flex;
			flex-direction: column;
		}
		.panel {
			position: relative;
			inset: auto;
			opacity: 1;
			transform: none;
			min-height: 100vh;
			padding: var(--stack-lg) var(--margin-edge);
		}
		.exp__blackout {
			display: none;
		}
		.panel__gfx--strategy .rail-line,
		.panel__gfx--architecture .links path {
			stroke-dashoffset: 0;
		}
		.panel__gfx--architecture .block {
			opacity: 1;
			transform: none;
		}
		.exec--mockup {
			opacity: 1;
		}
	}
</style>
