---
const navItems = [
	{ label: "Especialidad", href: "/#expertise" },
	{ label: "Soluciones", href: "/solutions/" },
	{ label: "Nosotros", href: "/about/" },
];
---

<header class="site-header">
	<div class="rail" aria-hidden="true">
		<div class="rail__glow" id="railGlow"></div>
	</div>
	<div class="rail__card">
		<a href="/" class="brand">RAIL</a>
		<nav class="nav" id="primary-nav" aria-label="Primary">
			{
				navItems.map((item) => (
					<a href={item.href} class="nav__link label-caps">
						{item.label}
					</a>
				))
			}
		</nav>
		<a href="/contact/" class="cta label-caps">Inicia un Proyecto</a>
		<button
			class="nav-toggle"
			type="button"
			aria-label="Abrir menú"
			aria-expanded="false"
			aria-controls="primary-nav"
		>
			<span class="nav-toggle__bar"></span>
			<span class="nav-toggle__bar"></span>
			<span class="nav-toggle__bar"></span>
		</button>
	</div>
</header>

<style>
	.site-header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		display: grid;
		place-items: center;
		padding: 12px var(--margin-edge);
	}

	.rail {
		position: absolute;
		inset: 0;
		pointer-events: none;
	}

	.rail__glow {
		position: absolute;
		top: 50%;
		left: 0px;
		transform: translate(-50%, -50%);
		width: 160px;
		height: 80px;
		background: radial-gradient(
			ellipse,
			rgba(147, 197, 114, 0.55) 0%,
			rgba(147, 197, 114, 0.18) 45%,
			transparent 70%
		);
		border-radius: 50%;
		transition: left 500ms cubic-bezier(0.4, 0, 0.2, 1);
	}

	.rail__card {
		position: relative;
		z-index: 1;
		width: 100%;
		max-width: var(--container-max);
		padding: 14px var(--gutter);
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: var(--stack-md);
		background: color-mix(in srgb, var(--surface) 75%, transparent);
		backdrop-filter: saturate(180%) blur(14px);
		-webkit-backdrop-filter: saturate(180%) blur(14px);
		border: 1px solid var(--outline-variant);
		border-radius: var(--r);
		box-shadow: 0 8px 40px rgba(0, 0, 0, 0.06);
	}

	.brand {
		font-weight: 800;
		font-size: 20px;
		letter-spacing: -0.02em;
		color: var(--on-surface);
	}

	.nav {
		display: flex;
		justify-content: center;
		gap: var(--stack-md);
	}

	.nav__link {
		color: var(--on-surface-variant);
		transition: color 200ms ease;
	}

	.nav__link:hover {
		color: var(--on-surface);
	}

	.cta {
		background: var(--tertiary);
		color: var(--on-tertiary);
		padding: 12px 20px;
		border-radius: var(--r);
		transition:
			transform 200ms ease,
			filter 200ms ease;
	}

	.cta:hover {
		transform: scale(1.02);
		filter: brightness(0.97);
	}

	/* Hamburger — hidden on desktop, shown on mobile */
	.nav-toggle {
		display: none;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 4px;
		width: 42px;
		height: 42px;
		padding: 0;
		background: transparent;
		border: 1px solid var(--outline-variant);
		border-radius: var(--r);
		cursor: pointer;
	}

	.nav-toggle__bar {
		width: 18px;
		height: 2px;
		border-radius: 2px;
		background: var(--on-surface);
		transition:
			transform 200ms ease,
			opacity 200ms ease;
	}

	@media (max-width: 768px) {
		.site-header {
			padding: 12px var(--stack-md);
		}

		.rail__card {
			padding: 12px var(--stack-md);
			grid-template-columns: 1fr auto auto;
			gap: var(--stack-sm);
		}

		.rail__glow {
			width: 80px;
			height: 40px;
		}

		.nav-toggle {
			display: inline-flex;
		}

		.nav {
			position: absolute;
			top: calc(100% + 8px);
			left: var(--stack-md);
			right: var(--stack-md);
			display: none;
			flex-direction: column;
			align-items: stretch;
			gap: 0;
			padding: 8px;
			background: var(--surface-container-lowest);
			border: 1px solid var(--outline-variant);
			border-radius: var(--r);
			box-shadow: 0 8px 40px rgba(0, 0, 0, 0.1);
		}

		.rail__card.is-open .nav {
			display: flex;
		}

		.nav__link {
			padding: 12px 8px;
		}

		.rail__card.is-open .nav-toggle__bar:nth-child(1) {
			transform: translateY(6px) rotate(45deg);
		}

		.rail__card.is-open .nav-toggle__bar:nth-child(2) {
			opacity: 0;
		}

		.rail__card.is-open .nav-toggle__bar:nth-child(3) {
			transform: translateY(-6px) rotate(-45deg);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.rail__glow {
			transition: none;
		}

		.nav-toggle__bar {
			transition: none;
		}
	}
</style>

<script>
	const glow = document.getElementById("railGlow") as HTMLElement | null;
	const header = document.querySelector(".site-header") as HTMLElement | null;
	const brand = document.querySelector(".brand") as HTMLElement | null;
	const card = document.querySelector(".rail__card") as HTMLElement | null;
	const toggle = document.querySelector(".nav-toggle") as HTMLButtonElement | null;

	// Hash id from an href like "/#expertise" or "#expertise"
	function hashOf(href: string | null): string | null {
		if (!href) return null;
		const i = href.indexOf("#");
		return i >= 0 ? href.slice(i + 1) : null;
	}

	// Mobile menu toggle
	if (card && toggle) {
		const closeMenu = () => {
			card.classList.remove("is-open");
			toggle.setAttribute("aria-expanded", "false");
			toggle.setAttribute("aria-label", "Abrir menú");
		};
		toggle.addEventListener("click", () => {
			const open = card.classList.toggle("is-open");
			toggle.setAttribute("aria-expanded", String(open));
			toggle.setAttribute("aria-label", open ? "Cerrar menú" : "Abrir menú");
		});
		card
			.querySelectorAll<HTMLElement>(".nav__link")
			.forEach((link) => link.addEventListener("click", closeMenu));
	}

	if (glow && header && brand) {
		// Map section id → nav link element
		const sectionLinks = new Map<string, HTMLElement>();
		document.querySelectorAll<HTMLElement>(".nav__link").forEach((link) => {
			const id = hashOf(link.getAttribute("href"));
			if (id) sectionLinks.set(id, link);
		});

		// Returns center X of el relative to header left edge
		function targetLeft(el: HTMLElement): number {
			const elRect = el.getBoundingClientRect();
			const headerRect = header!.getBoundingClientRect();
			return elRect.left + elRect.width / 2 - headerRect.left;
		}

		function moveGlow(el: HTMLElement) {
			glow!.style.left = `${targetLeft(el)}px`;
		}

		// Which section has scrolled past the viewport midpoint?
		const sections = [...sectionLinks.entries()]
			.map(([id, link]) => ({ el: document.getElementById(id), link }))
			.filter((s): s is { el: HTMLElement; link: HTMLElement } => s.el !== null);

		function getActiveLink(): HTMLElement {
			const mid = window.innerHeight / 2;
			let active: HTMLElement | null = null;
			for (const { el, link } of sections) {
				if (el.getBoundingClientRect().top <= mid) active = link;
			}
			return active ?? brand!;
		}

		function update() {
			moveGlow(getActiveLink());
		}

		window.addEventListener("scroll", update, { passive: true });
		window.addEventListener("resize", update);

		// Initial position after layout settles
		requestAnimationFrame(update);
	}

	// Custom anchor scroll: sections use sticky tracks with negative top margins,
	// so the native anchor lands on an empty pre-reveal frame. Aim at the scroll
	// position where each section's content is first meaningfully visible.
	const REVEAL_PROGRESS: Record<string, number> = {
		expertise: 0.12,
		solutions: 0.7,
	};

	function smoothScrollToSection(id: string) {
		const section = document.getElementById(id);
		if (!section) return;
		const track = section.querySelector<HTMLElement>(
			".exp__track, .sol__track",
		);
		const progress = REVEAL_PROGRESS[id] ?? 0;
		const sectionTop = section.getBoundingClientRect().top + window.scrollY;
		const trackHeight = track ? track.offsetHeight : section.offsetHeight;
		const target = sectionTop + progress * (trackHeight - window.innerHeight);
		window.scrollTo({ top: Math.max(0, target), behavior: "smooth" });
	}

	document.querySelectorAll<HTMLAnchorElement>(".nav__link").forEach((link) => {
		const id = hashOf(link.getAttribute("href"));
		if (!id || !(id in REVEAL_PROGRESS)) return;
		link.addEventListener("click", (e) => {
			// Only intercept when the section exists on this page (the home).
			// Otherwise let the browser navigate to "/#id".
			if (!document.getElementById(id)) return;
			e.preventDefault();
			smoothScrollToSection(id);
			if (history.replaceState) history.replaceState(null, "", `#${id}`);
		});
	});

	// Arriving on the home with a section hash (e.g. from another page): run the
	// reveal-aware scroll instead of the native jump to the pre-reveal frame.
	const initialId = location.hash.slice(1);
	if (initialId in REVEAL_PROGRESS && document.getElementById(initialId)) {
		requestAnimationFrame(() => smoothScrollToSection(initialId));
	}
</script>
